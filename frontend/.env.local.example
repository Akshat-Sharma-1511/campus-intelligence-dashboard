# Groq API key for Vercel AI SDK
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── Option A: Unified server (single Render deployment) ──────────────────────
# Set this ONE variable to your Render URL after deploying unified-server/
# UNIFIED_SERVER_URL=https://campus-mcp-unified.onrender.com

# ── Option B: Individual servers (local dev defaults) ────────────────────────
# If UNIFIED_SERVER_URL is not set, these are used instead:
LIBRARY_SERVER_URL=http://localhost:8001
CAFETERIA_SERVER_URL=http://localhost:8002
EVENTS_SERVER_URL=http://localhost:8003
HANDBOOK_SERVER_URL=http://localhost:8004
