# Groq API key for Vercel AI SDK
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# MCP server URLs
# Local dev defaults:
LIBRARY_SERVER_URL=http://localhost:8001
CAFETERIA_SERVER_URL=http://localhost:8002
EVENTS_SERVER_URL=http://localhost:8003
HANDBOOK_SERVER_URL=http://localhost:8004

# Production (Render) — uncomment and fill in after deploying to Render:
# LIBRARY_SERVER_URL=https://campus-library-server.onrender.com
# CAFETERIA_SERVER_URL=https://campus-cafeteria-server.onrender.com
# EVENTS_SERVER_URL=https://campus-events-server.onrender.com
# HANDBOOK_SERVER_URL=https://campus-handbook-server.onrender.com
